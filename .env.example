# FLASK APP CONFIG
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=dev-secret-key
PORT=5200
HOST=0.0.0.0

# DATABASE CONFIG (PostgreSQL)
DB_HOST=postgres_dev
DB_PORT=5432
DB_NAME=hubspot_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

# DLT CONFIG
DLT_PIPELINE_NAME=hubspot_deals
DLT_WORKING_DIR=.dlt

# HUBSPOT API CONFIG
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_ACCESS_TOKEN=your_token_here
HUBSPOT_API_TIMEOUT=30
HUBSPOT_API_RATE_LIMIT=150

# SERVICE CONFIG
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_HOURS=24
CLEANUP_DAYS=7

# LOGGING CONFIG
LOG_LEVEL=INFO
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100
LOKI_USERNAME=
LOKI_PASSWORD=
